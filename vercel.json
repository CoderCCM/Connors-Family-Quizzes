{
    "version": 2,
    "builds": [
      {
        "src": "api/index.js",
        "use": "@vercel/node"
      }
    ],
    "routes": [
      { "src": "/(5|437143714371|scoreboard)?", "dest": "/api/index.js" },
      { "src": "/", "dest": "/api/index.js" },
      { "src": "/(.*\\.css)", "dest": "/public/$1" },
      { "src": "/(.*\\.js)", "dest": "/public/$1" }
    ]
  }